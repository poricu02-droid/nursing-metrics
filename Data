<!DOCTYPE html>
<html lang="th">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Nursing Metrics Reporting System</title>
    <script src="https://unpkg.com/@babel/standalone/babel.min.js"></script>
    <script crossorigin src="https://unpkg.com/react@18/umd/react.production.min.js"></script>
    <script crossorigin src="https://unpkg.com/react-dom@18/umd/react-dom.production.min.js"></script>
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/3.9.1/chart.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/html2pdf.js/0.10.1/html2pdf.bundle.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/xlsx/0.18.5/xlsx.min.js"></script>
    <style>
        .icon { display: inline-block; margin-right: 6px; }
        .chart-container { position: relative; height: 400px; margin: 20px 0; }
    </style>
</head>
<body>
    <div id="root"></div>

    <script type="text/babel">
        const { useState, useEffect, useRef } = React;

        const NursingMetricsApp = () => {
            const API_URL = 'https://script.google.com/macros/s/AKfycbyG8MW_mm85w1ewGmqbCL13YJnNY_MLPxzFjL0bU5zt94nWi7eMGfQ4WtsElSGVAFJo/exec';
            
            const [activeTab, setActiveTab] = useState('dashboard');
            const [loading, setLoading] = useState(false);
            const [allData, setAllData] = useState([]);
            const [indicators, setIndicators] = useState([]);

            const departmentsList = [
                { id: 'NG01', name: 'กลุ่มการพยาบาล', manager: 'อ.สมชาย' },
                { id: 'NG02', name: 'การพยาบาลชุมชน', manager: 'อ.สมหญิง' },
                { id: 'NG03', name: 'อาชีวเวชกรรม', manager: 'อ.สมคิด' },
                { id: 'NG04', name: 'เวชกรรมสังคม', manager: 'อ.สมโภค' },
                { id: 'NG05', name: 'ห้องคลอด', manager: 'อ.สมใจ' },
                { id: 'NG06', name: 'อุบัติเหตุ-ฉุกเฉิน', manager: 'อ.สมดี' },
                { id: 'NG07', name: 'ห้องผ่าตัด', manager: 'อ.สมหวัง' },
                { id: 'NG08', name: 'วิสัญญี', manager: 'อ.สมพร' },
                { id: 'NG09', name: 'พิเศษสงฆ์อาพาธ', manager: 'อ.สมจิตร' },
                { id: 'NG10', name: 'พิเศษ75เตียง', manager: 'อ.สมเกียรติ' },
                { id: 'NG11', name: 'พิเศษสมเด็จเกี่ยว', manager: 'อ.สมจันทร์' },
                { id: 'NG12', name: 'พิเศษมารีน่า', manager: 'อ.สมนึก' },
                { id: 'NG13', name: 'พิเศษสมเด็จเกี่ยว2', manager: 'อ.สมวงค์' },
                { id: 'NG14', name: 'พิเศษสมเด็จเกี่ยว3', manager: 'อ.สมยศ' },
                { id: 'NG15', name: 'ผู้ป่วยนอก', manager: 'อ.สมหล่อ' },
                { id: 'NG16', name: 'ไตเทียม', manager: 'อ.สมสัน' },
                { id: 'NG17', name: 'ส่องกล้อง', manager: 'อ.สมหนึ่ง' },
                { id: 'NG18', name: 'เคมีบำบัด', manager: 'อ.สมหาย' },
                { id: 'NG19', name: 'สูติ-กุมาร', manager: 'อ.สมเดช' },
            ];

            const fetchData = async (action, params = {}) => {
                setLoading(true);
                try {
                    let url = `${API_URL}?action=${action}`;
                    Object.keys(params).forEach(key => {
                        url += `&${key}=${encodeURIComponent(params[key])}`;
                    });
                    const response = await fetch(url);
                    const result = await response.json();
                    if (result.success) {
                        setLoading(false);
                        return result.data;
                    }
                } catch (error) {
                    console.error('Fetch error:', error);
                }
                setLoading(false);
                return null;
            };

            useEffect(() => {
                const loadData = async () => {
                    const data = await fetchData('getAllData');
                    if (data) setAllData(data);
                    const inds = await fetchData('getIndicators');
                    if (inds) setIndicators(inds);
                };
                loadData();
            }, []);

            // Dashboard Component
            const Dashboard = () => {
                const passCount = allData.filter(d => d.pass_fail === 'ผ่าน').length;
                const deptPerformance = {};
                allData.forEach(d => {
                    if (!deptPerformance[d.hospital]) {
                        deptPerformance[d.hospital] = { pass: 0, total: 0 };
                    }
                    deptPerformance[d.hospital].total++;
                    if (d.pass_fail === 'ผ่าน') deptPerformance[d.hospital].pass++;
                });

                const chartRef = useRef(null);
                useEffect(() => {
                    if (!chartRef.current) return;
                    const ctx = chartRef.current.getContext('2d');
                    const labels = Object.keys(deptPerformance).slice(0, 10);
                    const passData = labels.map(k => deptPerformance[k].pass);
                    const failData = labels.map(k => deptPerformance[k].total - deptPerformance[k].pass);
                    const chart = new Chart(ctx, {
                        type: 'bar',
                        data: {
                            labels,
                            datasets: [
                                { label: 'ผ่าน', data: passData, backgroundColor: 'rgba(34,197,94,0.6)' },
                                { label: 'ไม่ผ่าน', data: failData, backgroundColor: 'rgba(239,68,68,0.6)' },
                            ]
                        },
                        options: { responsive: true, maintainAspectRatio: false }
                    });
                    return () => chart.destroy();
                }, [allData]);

                return (
                    <div className="space-y-6">
                        <div className="grid grid-cols-1 md:grid-cols-4 gap-4">
                            <div className="bg-gradient-to-br from-blue-50 to-blue-100 p-6 rounded-lg border border-blue-200">
                                <h3 className="text-sm font-medium text-blue-900">ตัวชี้วัดทั้งหมด</h3>
                                <p className="text-3xl font-bold text-blue-600 mt-2">{indicators.length}</p>
                            </div>
                            <div className="bg-gradient-to-br from-green-50 to-green-100 p-6 rounded-lg border border-green-200">
                                <h3 className="text-sm font-medium text-green-900">ผ่านเกณฑ์</h3>
                                <p className="text-3xl font-bold text-green-600 mt-2">{passCount}</p>
                            </div>
                            <div className="bg-gradient-to-br from-orange-50 to-orange-100 p-6 rounded-lg border border-orange-200">
                                <h3 className="text-sm font-medium text-orange-900">หน่วยงาน</h3>
                                <p className="text-3xl font-bold text-orange-600 mt-2">{departmentsList.length}</p>
                            </div>
                            <div className="bg-gradient-to-br from-purple-50 to-purple-100 p-6 rounded-lg border border-purple-200">
                                <h3 className="text-sm font-medium text-purple-900">ข้อมูลทั้งหมด</h3>
                                <p className="text-3xl font-bold text-purple-600 mt-2">{allData.length}</p>
                            </div>
                        </div>

                        <div className="bg-white p-6 rounded-lg border border-gray-200">
                            <h3 className="text-lg font-semibold mb-4">📊 ผลการปฏิบัติตามหน่วยงาน</h3>
                            <div className="chart-container">
                                <canvas ref={chartRef}></canvas>
                            </div>
                        </div>

                        <div className="bg-white p-6 rounded-lg border border-gray-200">
                            <h3 className="text-lg font-semibold mb-4">📈 ข้อมูลล่าสุด</h3>
                            <div className="overflow-x-auto">
                                <table className="w-full text-sm">
                                    <thead>
                                        <tr className="border-b bg-gray-50">
                                            <th className="text-left p-3">หน่วยงาน</th>
                                            <th className="text-left p-3">ตัวชี้วัด</th>
                                            <th className="text-center p-3">ค่า</th>
                                            <th className="text-center p-3">สถานะ</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        {allData.slice(-10).map((d, i) => (
                                            <tr key={i} className="border-b hover:bg-gray-50">
                                                <td className="p-3">{d.hospital}</td>
                                                <td className="p-3 text-xs">{d.indicator_name?.substring(0, 40)}</td>
                                                <td className="p-3 text-center">{d.result_value}</td>
                                                <td className="p-3 text-center">
                                                    <span className={`px-2 py-1 rounded text-xs font-medium ${
                                                        d.pass_fail === 'ผ่าน'
                                                            ? 'bg-green-100 text-green-700'
                                                            : 'bg-red-100 text-red-700'
                                                    }`}>
                                                        {d.pass_fail || '—'}
                                                    </span>
                                                </td>
                                            </tr>
                                        ))}
                                    </tbody>
                                </table>
                                {allData.length === 0 && (
                                    <p className="text-center py-8 text-gray-500">ไม่มีข้อมูล</p>
                                )}
                            </div>
                        </div>
                    </div>
                );
            };

            // Data Entry Component
            const DataEntry = () => {
                const [formData, setFormData] = useState({
                    year: 2569,
                    hospital: '',
                    indicator_id: '',
                    indicator_name: '',
                    indicator_type: '',
                    result_value: '',
                    pass_fail: 'ผ่าน',
                    month: 'ต.ค.'
                });

                const handleSubmit = async (e) => {
                    e.preventDefault();
                    setLoading(true);
                    try {
                        const response = await fetch(API_URL, {
                            method: 'POST',
                            headers: { 'Content-Type': 'application/json' },
                            body: JSON.stringify({
                                action: 'addRecord',
                                ...formData,
                                extra_data: { month: formData.month }
                            })
                        });
                        const result = await response.json();
                        if (result.success) {
                            alert('บันทึกข้อมูลสำเร็จ!');
                            setFormData({...formData, result_value: '', pass_fail: 'ผ่าน'});
                            const data = await fetchData('getAllData');
                            if (data) setAllData(data);
                        }
                    } catch (error) {
                        alert('เกิดข้อผิดพลาด: ' + error);
                    }
                    setLoading(false);
                };

                const months = ['ม.ค.','ก.พ.','มี.ค.','เม.ย.','พ.ค.','มิ.ย.','ก.ค.','ส.ค.','ก.ย.','ต.ค.','พ.ย.','ธ.ค.'];

                return (
                    <div className="space-y-6">
                        <div className="bg-white p-6 rounded-lg border border-gray-200">
                            <h3 className="text-lg font-semibold mb-4">📝 เพิ่มข้อมูลใหม่</h3>
                            <form onSubmit={handleSubmit} className="space-y-4">
                                <div className="grid grid-cols-1 md:grid-cols-2 gap-4">
                                    <div>
                                        <label className="block text-sm font-medium mb-2">หน่วยงาน</label>
                                        <select
                                            value={formData.hospital}
                                            onChange={(e) => setFormData({...formData, hospital: e.target.value})}
                                            className="w-full p-2 border rounded text-sm"
                                            required
                                        >
                                            <option value="">เลือกหน่วยงาน</option>
                                            {departmentsList.map(d => (
                                                <option key={d.id} value={d.name}>{d.name}</option>
                                            ))}
                                        </select>
                                    </div>

                                    <div>
                                        <label className="block text-sm font-medium mb-2">เดือน</label>
                                        <select
                                            value={formData.month}
                                            onChange={(e) => setFormData({...formData, month: e.target.value})}
                                            className="w-full p-2 border rounded text-sm"
                                        >
                                            {months.map(m => <option key={m}>{m}</option>)}
                                        </select>
                                    </div>

                                    <div>
                                        <label className="block text-sm font-medium mb-2">รหัสตัวชี้วัด</label>
                                        <input
                                            type="text"
                                            value={formData.indicator_id}
                                            onChange={(e) => setFormData({...formData, indicator_id: e.target.value})}
                                            className="w-full p-2 border rounded text-sm"
                                            placeholder="เช่น NSO-OUT-01"
                                            required
                                        />
                                    </div>

                                    <div>
                                        <label className="block text-sm font-medium mb-2">ชื่อตัวชี้วัด</label>
                                        <input
                                            type="text"
                                            value={formData.indicator_name}
                                            onChange={(e) => setFormData({...formData, indicator_name: e.target.value})}
                                            className="w-full p-2 border rounded text-sm"
                                            required
                                        />
                                    </div>

                                    <div>
                                        <label className="block text-sm font-medium mb-2">ประเภท</label>
                                        <input
                                            type="text"
                                            value={formData.indicator_type}
                                            onChange={(e) => setFormData({...formData, indicator_type: e.target.value})}
                                            className="w-full p-2 border rounded text-sm"
                                            placeholder="เช่น NSO ผลลัพธ์"
                                        />
                                    </div>

                                    <div>
                                        <label className="block text-sm font-medium mb-2">ค่า</label>
                                        <input
                                            type="text"
                                            value={formData.result_value}
                                            onChange={(e) => setFormData({...formData, result_value: e.target.value})}
                                            className="w-full p-2 border rounded text-sm"
                                            placeholder="เช่น 95.5"
                                            required
                                        />
                                    </div>

                                    <div>
                                        <label className="block text-sm font-medium mb-2">สถานะ</label>
                                        <select
                                            value={formData.pass_fail}
                                            onChange={(e) => setFormData({...formData, pass_fail: e.target.value})}
                                            className="w-full p-2 border rounded text-sm"
                                        >
                                            <option>ผ่าน</option>
                                            <option>ไม่ผ่าน</option>
                                        </select>
                                    </div>

                                    <div>
                                        <label className="block text-sm font-medium mb-2">ปี</label>
                                        <select
                                            value={formData.year}
                                            onChange={(e) => setFormData({...formData, year: Number(e.target.value)})}
                                            className="w-full p-2 border rounded text-sm"
                                        >
                                            {[2567,2568,2569,2570].map(y => <option key={y} value={y}>{y}</option>)}
                                        </select>
                                    </div>
                                </div>

                                <button
                                    type="submit"
                                    disabled={loading}
                                    className="w-full bg-blue-600 text-white py-2 rounded-lg hover:bg-blue-700 disabled:bg-gray-400 font-medium"
                                >
                                    {loading ? '⏳ กำลังบันทึก...' : '💾 บันทึกข้อมูล'}
                                </button>
                            </form>
                        </div>
                    </div>
                );
            };

            // Reports Component
            const Reports = () => {
                const [filters, setFilters] = useState({ hospital: '', indicator_id: '', year: 2569, month: '' });
                const [reportData, setReportData] = useState([]);
                const months = ['ม.ค.','ก.พ.','มี.ค.','เม.ย.','พ.ค.','มิ.ย.','ก.ค.','ส.ค.','ก.ย.','ต.ค.','พ.ย.','ธ.ค.'];

                const handleSearch = async () => {
                    const params = { year: filters.year };
                    if (filters.hospital) params.hospital = filters.hospital;
                    if (filters.indicator_id) params.indicator_id = filters.indicator_id;
                    if (filters.month) params.month = filters.month;
                    const data = await fetchData('getByFilters', params);
                    if (data) setReportData(data);
                };

                const exportPDF = () => {
                    const element = document.getElementById('reportTable');
                    html2pdf().set({
                        margin: 10,
                        filename: 'nursing-metrics-report.pdf',
                        image: { type: 'jpeg', quality: 0.98 },
                        html2canvas: { scale: 2 },
                        jsPDF: { orientation: 'landscape', unit: 'mm', format: 'a4' }
                    }).from(element).save();
                };

                const exportExcel = () => {
                    const ws = XLSX.utils.json_to_sheet(reportData);
                    const wb = XLSX.utils.book_new();
                    XLSX.utils.book_append_sheet(wb, ws, "Reports");
                    XLSX.writeFile(wb, "nursing-metrics-report.xlsx");
                };

                return (
                    <div className="space-y-6">
                        <div className="bg-white p-6 rounded-lg border border-gray-200">
                            <h3 className="text-lg font-semibold mb-4">🔍 ค้นหารายงาน</h3>
                            <div className="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4 mb-6">
                                <div>
                                    <label className="block text-sm font-medium mb-2">หน่วยงาน</label>
                                    <select
                                        value={filters.hospital}
                                        onChange={(e) => setFilters({...filters, hospital: e.target.value})}
                                        className="w-full p-2 border rounded text-sm"
                                    >
                                        <option value="">ทั้งหมด</option>
                                        {departmentsList.map(d => (
                                            <option key={d.id} value={d.name}>{d.name}</option>
                                        ))}
                                    </select>
                                </div>
                                <div>
                                    <label className="block text-sm font-medium mb-2">ตัวชี้วัด</label>
                                    <select
                                        value={filters.indicator_id}
                                        onChange={(e) => setFilters({...filters, indicator_id: e.target.value})}
                                        className="w-full p-2 border rounded text-sm"
                                    >
                                        <option value="">ทั้งหมด</option>
                                        {indicators.map((ind, i) => (
                                            <option key={i} value={ind.id}>{ind.id}</option>
                                        ))}
                                    </select>
                                </div>
                                <div>
                                    <label className="block text-sm font-medium mb-2">เดือน</label>
                                    <select
                                        value={filters.month}
                                        onChange={(e) => setFilters({...filters, month: e.target.value})}
                                        className="w-full p-2 border rounded text-sm"
                                    >
                                        <option value="">ทั้งหมด</option>
                                        {months.map(m => <option key={m} value={m}>{m}</option>)}
                                    </select>
                                </div>
                                <div>
                                    <label className="block text-sm font-medium mb-2">ปี</label>
                                    <select
                                        value={filters.year}
                                        onChange={(e) => setFilters({...filters, year: Number(e.target.value)})}
                                        className="w-full p-2 border rounded text-sm"
                                    >
                                        {[2567,2568,2569,2570].map(y => <option key={y} value={y}>{y}</option>)}
                                    </select>
                                </div>
                            </div>
                            <div className="flex flex-wrap gap-3">
                                <button onClick={handleSearch} disabled={loading}
                                    className="px-6 py-2 bg-blue-600 text-white rounded-lg hover:bg-blue-700 disabled:bg-gray-400">
                                    🔍 ค้นหา
                                </button>
                                <button onClick={exportPDF} disabled={reportData.length === 0}
                                    className="px-4 py-2 bg-red-600 text-white rounded-lg hover:bg-red-700 disabled:bg-gray-400">
                                    📄 Export PDF
                                </button>
                                <button onClick={exportExcel} disabled={reportData.length === 0}
                                    className="px-4 py-2 bg-green-600 text-white rounded-lg hover:bg-green-700 disabled:bg-gray-400">
                                    📊 Export Excel
                                </button>
                            </div>
                        </div>

                        <div className="bg-white p-6 rounded-lg border border-gray-200">
                            <h3 className="text-lg font-semibold mb-4">📊 ผลการค้นหา ({reportData.length})</h3>
                            <div id="reportTable" className="overflow-x-auto">
                                <table className="w-full text-sm">
                                    <thead>
                                        <tr className="border-b bg-gray-50">
                                            <th className="text-left p-3">หน่วยงาน</th>
                                            <th className="text-left p-3">ตัวชี้วัด</th>
                                            <th className="text-center p-3">ค่า</th>
                                            <th className="text-center p-3">สถานะ</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        {reportData.map((d, i) => (
                                            <tr key={i} className="border-b hover:bg-gray-50">
                                                <td className="p-3">{d.hospital}</td>
                                                <td className="p-3 text-xs">{d.indicator_name?.substring(0, 50)}</td>
                                                <td className="p-3 text-center">{d.result_value}</td>
                                                <td className="p-3 text-center">
                                                    <span className={`px-2 py-1 rounded text-xs font-medium ${
                                                        d.pass_fail === 'ผ่าน'
                                                            ? 'bg-green-100 text-green-700'
                                                            : 'bg-red-100 text-red-700'
                                                    }`}>
                                                        {d.pass_fail || '—'}
                                                    </span>
                                                </td>
                                            </tr>
                                        ))}
                                    </tbody>
                                </table>
                                {reportData.length === 0 && (
                                    <p className="text-center py-8 text-gray-500">กรุณาค้นหาข้อมูล</p>
                                )}
                            </div>
                        </div>
                    </div>
                );
            };

            // Quality Metrics Component
            const QualityMetrics = () => (
                <div className="space-y-6">
                    <div className="bg-white p-6 rounded-lg border border-gray-200">
                        <h3 className="text-lg font-semibold mb-4">⭐ ตัวชี้วัดคุณภาพการพยาบาล</h3>
                        <div className="grid grid-cols-1 md:grid-cols-2 gap-4">
                            {indicators.map((metric, idx) => (
                                <div key={idx} className="p-4 border rounded-lg hover:bg-blue-50">
                                    <p className="font-medium text-sm">{metric.name}</p>
                                    <p className="text-xs text-gray-600 mt-1">{metric.type}</p>
                                    <span className="inline-block bg-blue-100 text-blue-700 px-2 py-1 rounded text-xs font-medium mt-2">
                                        {metric.id}
                                    </span>
                                </div>
                            ))}
                            {indicators.length === 0 && (
                                <p className="text-gray-500 text-sm col-span-2">ไม่มีข้อมูลตัวชี้วัด</p>
                            )}
                        </div>
                    </div>
                </div>
            );

            // Settings Component
            const Settings = () => (
                <div className="space-y-6">
                    <div className="bg-white p-6 rounded-lg border border-gray-200">
                        <h3 className="text-lg font-semibold mb-4">👥 จัดการหน่วยงาน</h3>
                        <div className="grid grid-cols-1 md:grid-cols-2 gap-4">
                            {departmentsList.map(dept => (
                                <div key={dept.id} className="p-4 border rounded-lg">
                                    <p className="font-medium">{dept.name}</p>
                                    <p className="text-sm text-gray-600">{dept.manager}</p>
                                    <span className="inline-block bg-gray-100 text-gray-700 px-2 py-1 rounded text-xs mt-2">
                                        {dept.id}
                                    </span>
                                </div>
                            ))}
                        </div>
                    </div>

                    <div className="bg-white p-6 rounded-lg border border-gray-200">
                        <h3 className="text-lg font-semibold mb-4">🔗 API Connection</h3>
                        <div className="space-y-3">
                            <div className="flex items-center gap-3 p-3 bg-green-50 border border-green-200 rounded">
                                <span className="text-2xl">✅</span>
                                <div>
                                    <p className="font-medium text-sm">Google Apps Script</p>
                                    <p className="text-xs text-gray-600">เชื่อมต่อสำเร็จ</p>
                                </div>
                            </div>
                            <div className="flex items-center gap-3 p-3 bg-green-50 border border-green-200 rounded">
                                <span className="text-2xl">✅</span>
                                <div>
                                    <p className="font-medium text-sm">Google Sheets</p>
                                    <p className="text-xs text-gray-600">ข้อมูล {allData.length} records</p>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            );

            const tabs = [
                { id: 'dashboard', label: '📊 Dashboard' },
                { id: 'entry', label: '📝 Data Entry' },
                { id: 'reports', label: '📄 Reports' },
                { id: 'quality', label: '⭐ Quality Metrics' },
                { id: 'settings', label: '⚙️ Settings' },
            ];

            return (
                <div className="min-h-screen bg-gray-100">
                    {/* Header */}
                    <div className="bg-gradient-to-r from-blue-600 to-blue-800 text-white sticky top-0 z-20">
                        <div className="max-w-7xl mx-auto px-4 py-6">
                            <h1 className="text-3xl font-bold">🏥 Nursing Metrics Reporting System</h1>
                            <p className="text-blue-100 mt-1">ระบบรายงานตัวชี้วัดการพยาบาล กองการพยาบาล ประจำปี 2569</p>
                        </div>
                    </div>

                    {/* Navigation */}
                    <div className="bg-white border-b border-gray-200 sticky top-[88px] z-10">
                        <div className="max-w-7xl mx-auto px-4">
                            <div className="flex gap-1 overflow-x-auto">
                                {tabs.map(tab => (
                                    <button
                                        key={tab.id}
                                        onClick={() => setActiveTab(tab.id)}
                                        className={`px-4 py-3 font-medium border-b-2 transition-colors whitespace-nowrap ${
                                            activeTab === tab.id
                                                ? 'border-blue-600 text-blue-600'
                                                : 'border-transparent text-gray-600 hover:text-gray-900'
                                        }`}
                                    >
                                        {tab.label}
                                    </button>
                                ))}
                            </div>
                        </div>
                    </div>

                    {/* Loading */}
                    {loading && (
                        <div className="bg-blue-100 text-blue-700 p-3 text-center">
                            ⏳ กำลังโหลด...
                        </div>
                    )}

                    {/* Content */}
                    <div className="max-w-7xl mx-auto px-4 py-8">
                        {activeTab === 'dashboard' && <Dashboard />}
                        {activeTab === 'entry' && <DataEntry />}
                        {activeTab === 'reports' && <Reports />}
                        {activeTab === 'quality' && <QualityMetrics />}
                        {activeTab === 'settings' && <Settings />}
                    </div>

                    {/* Footer */}
                    <div className="bg-white border-t border-gray-200 mt-12">
                        <div className="max-w-7xl mx-auto px-4 py-6 text-center text-sm text-gray-600">
                            <p>© 2569 Nursing Department Metrics System</p>
                            <p>Last Updated: {new Date().toLocaleDateString('th-TH')}</p>
                        </div>
                    </div>
                </div>
            );
        };

        ReactDOM.createRoot(document.getElementById('root')).render(<NursingMetricsApp />);
    </script>
</body>
</html>
